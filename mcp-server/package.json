{
  "name": "ai-town-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP endpoint that lets external agents connect to AI Town as clients (the town acts like a chatroom).",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "convex": "^1.41.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vitest": "^2.1.8"
  }
}
